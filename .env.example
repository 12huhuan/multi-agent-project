# Cross-Border Agents — Environment Configuration

# ── LLM 配置 ──
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_MODEL_SIMPLE=deepseek-chat

# ── 数据库 ──
POSTGRES_USER=cb_user
POSTGRES_PASSWORD=cb_pass_2026
POSTGRES_DB=crossborder
DATABASE_URL=postgresql+asyncpg://cb_user:cb_pass_2026@localhost:5432/crossborder
DATABASE_URL_SYNC=postgresql://cb_user:cb_pass_2026@localhost:5432/crossborder

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── ChromaDB ──
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=knowledge_base

# ── 安全 ──
SECRET_KEY=cb-agents-secret-change-in-production

# ── MCP 外部服务 API Keys ──
REPLICATE_API_TOKEN=
MINIMAX_API_KEY=
MINIMAX_API_HOST=https://api.minimax.io
DEEPL_API_KEY=

# ── 部署模式 ──
DEPLOYMENT_MODE=development
LOG_LEVEL=INFO
DEBUG=true
